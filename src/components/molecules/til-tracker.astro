---
interface Cell {
  isPad: boolean
  date: string | null
  hasEntry: boolean
  isFuture: boolean
}

interface Props {
  entryDates: Set<string>
  initialDate: string
  monthsToShow?: number
}

const { entryDates, initialDate, monthsToShow = 5 } = Astro.props

const todayStr = new Date().toISOString().slice(0, 10)
const now = new Date()

const trackerMonths = Array.from({ length: monthsToShow }, (_, i) => {
  const d = new Date(now.getFullYear(), now.getMonth() - (monthsToShow - 1 - i), 1)
  const year = d.getFullYear()
  const month = d.getMonth()
  const daysInMonth = new Date(year, month + 1, 0).getDate()
  // Sunday-first offset: Sun=0 … Sat=6
  const sundayOffset = new Date(year, month, 1).getDay()

  const cells: Cell[] = []

  for (let i = 0; i < sundayOffset; i++) {
    cells.push({ isPad: true, date: null, hasEntry: false, isFuture: false })
  }
  for (let day = 1; day <= daysInMonth; day++) {
    const dateStr = `${year}-${String(month + 1).padStart(2, "0")}-${String(day).padStart(2, "0")}`
    cells.push({
      isPad: false,
      date: dateStr,
      hasEntry: entryDates.has(dateStr),
      isFuture: dateStr > todayStr,
    })
  }
  // Pad to 42 cells so every month occupies exactly 6 rows
  while (cells.length < 42) {
    cells.push({ isPad: true, date: null, hasEntry: false, isFuture: false })
  }

  const label = d.toLocaleDateString("en-GB", { month: "short", year: "numeric" })
  const yearMonth = `${year}-${String(month + 1).padStart(2, "0")}`
  return { label, yearMonth, cells }
})
---

<div class="til-tracker" aria-hidden="true">
  {trackerMonths.map(({ label, yearMonth, cells }) => (
    <div class="tracker-month" data-year-month={yearMonth}>
      <div class="tracker-month-label">{label}</div>
      <div class="tracker-grid">
        {["S", "M", "T", "W", "T", "F", "S"].map(d => (
          <div class="tracker-day-header">{d}</div>
        ))}
        {cells.map(cell => (
          <div
            class:list={[
              "tracker-cell",
              cell.isPad && "tracker-cell--pad",
              !cell.isPad && !cell.hasEntry && !cell.isFuture && "tracker-cell--empty",
              cell.hasEntry && "tracker-cell--has-entry",
              cell.isFuture && "tracker-cell--future",
              cell.date === initialDate && "tracker-cell--active",
            ]}
            data-date={cell.date ?? undefined}
          ></div>
        ))}
      </div>
    </div>
  ))}
</div>

<style>
  /*
   * Each month block is 6.8125rem wide (7 × 0.8125rem cells + 6 × 0.1875rem gaps).
   * Mobile content width is viewport − 5.625rem (container + card padding at 18px font).
   * Desktop content width is fixed at 41.25rem (45rem container − 3.75rem card padding).
   *
   * 1 month:  6.8125rem → any width          (base)
   * 2 months: 15.0625rem → viewport ≥ 20.6875rem
   * 3 months: 23.3125rem → viewport ≥ 28.9375rem
   * 4 months: 31.9375rem → viewport ≥ 37.5625rem
   * 5 months: 40.3125rem → viewport ≥ 46.5625rem
   */
  .til-tracker {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    overflow: hidden;
  }

  .tracker-month {
    flex-shrink: 0;
  }

  /* Month visibility is controlled entirely by JS (updateTrackerWindow) */

  .tracker-month-label {
    font-size: 0.65rem;
    color: rgb(var(--gray));
    text-transform: uppercase;
    letter-spacing: 0.05rem;
    margin-bottom: 0.25rem;
  }

  .tracker-grid {
    display: grid;
    grid-template-columns: repeat(7, 0.8125rem);
    gap: 0.1875rem;
  }

  .tracker-day-header {
    width: 0.8125rem;
    height: 0.8125rem;
    font-size: 0.4375rem;
    color: rgb(var(--gray));
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tracker-cell {
    width: 0.8125rem;
    height: 0.8125rem;
    border-radius: 0.125rem;
  }

  .tracker-cell--pad {
    background: transparent;
  }

  .tracker-cell--empty {
    background: rgb(var(--gray-light));
  }

  .tracker-cell--future {
    background: rgb(var(--gray-light));
    opacity: 0.4;
  }

  .tracker-cell--has-entry {
    background: rgba(35, 55, 255, 0.35);
    cursor: pointer;
    transition: transform 0.1s ease, background 0.1s ease;
  }

  .tracker-cell--has-entry:hover {
    background: rgba(35, 55, 255, 0.6);
    transform: scale(1.25);
  }

  .tracker-cell--active,
  .tracker-cell--has-entry.tracker-cell--active {
    background: var(--accent);
    box-shadow: 0 0 0 0.09375rem var(--accent-dark);
  }
</style>
