---
import { getCollection, render } from "astro:content"
import TilTracker from "./til-tracker.astro"

const entries = await getCollection("til")

const sorted = entries.sort((a, b) =>
  new Date(b.id).getTime() - new Date(a.id).getTime(),
)

const rendered = await Promise.all(sorted.map(entry => render(entry)))

const WEEKDAYS = ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"]

const dayLabels = sorted.map((entry) => {
  const [year, month, day] = entry.id.split("-").map(Number)
  const weekday = WEEKDAYS[new Date(Date.UTC(year, month - 1, day)).getUTCDay()]
  return `${weekday} ${day}`
})

const entryDates = new Set(sorted.map(e => e.id))
const initialDate = sorted[0]?.id ?? ""

// Cover every entry's month, then round up to the nearest multiple of the
// max visible count (5) so mod paging always produces clean, non-overlapping
// pages at every viewport size. Extra months render as empty gray cells.
const MAX_VISIBLE = 5
const now = new Date()
const oldestId = sorted[sorted.length - 1]?.id ?? "1970-01-01"
const oldestDate = new Date(`${oldestId}T00:00:00Z`)
const rawMonthsNeeded = (now.getFullYear() - oldestDate.getFullYear()) * 12
  + (now.getMonth() - oldestDate.getMonth())
  + 1
const monthsToShow = Math.ceil(rawMonthsNeeded / MAX_VISIBLE) * MAX_VISIBLE
---

<aside class="til-card">
  <div class="til-card-header">
    <div class="til-card-header-top">
      <span class="til-label">Today I Learned</span>
      <div class="til-controls">
        <button id="til-older" aria-label="Older entry" disabled={sorted.length <= 1}>← Older</button>
        <time id="til-date" datetime={sorted[0].id}>{sorted[0].id}</time>
        <button id="til-newer" aria-label="Newer entry" disabled>Newer →</button>
      </div>
    </div>
    <TilTracker entryDates={entryDates} initialDate={initialDate} monthsToShow={monthsToShow} />
  </div>

  <div class="til-entries">
    {rendered.map(({ Content }, i) => (
      <div class="til-entry" data-date={sorted[i].id} hidden={i !== 0}>
        <p class="til-day">{dayLabels[i]}</p>
        <Content />
      </div>
    ))}
  </div>
  <div class="til-card-footer">
    <a href="/til-rss.xml" class="til-rss-link">TIL RSS</a>
  </div>
</aside>

<script>
  const entries = document.querySelectorAll<HTMLElement>(".til-entry")
  const dateEl = document.getElementById("til-date")
  const newerBtn = document.getElementById("til-newer") as HTMLButtonElement
  const olderBtn = document.getElementById("til-older") as HTMLButtonElement
  const trackerCells = document.querySelectorAll<HTMLElement>(".tracker-cell[data-date]")
  const trackerMonthEls = Array.from(document.querySelectorAll<HTMLElement>(".tracker-month"))

  let current = 0

  function getVisibleMonthCount(): number {
    const w = window.innerWidth
    if (w >= 745) {
      return 5
    }
    if (w >= 601) {
      return 4
    }
    if (w >= 463) {
      return 3
    }
    if (w >= 331) {
      return 2
    }
    return 1
  }

  function updateTrackerWindow(date: string) {
    if (!trackerMonthEls.length) {
      return
    }

    const yearMonth = date.slice(0, 7)
    let activeIdx = trackerMonthEls.findIndex(m => m.dataset.yearMonth === yearMonth)
    if (activeIdx === -1) {
      activeIdx = trackerMonthEls.length - 1
    }

    const count = getVisibleMonthCount()
    let start = activeIdx - (activeIdx % count)
    start = Math.min(start, trackerMonthEls.length - count)
    start = Math.max(0, start)
    const end = start + count

    trackerMonthEls.forEach((m, i) => {
      m.style.display = i >= start && i < end ? "block" : "none"
    })
  }

  function highlightDate(date: string) {
    trackerCells.forEach((cell) => {
      cell.classList.toggle("tracker-cell--active", cell.dataset.date === date)
    })
  }

  function show(index: number) {
    entries[current].hidden = true
    entries[index].hidden = false
    current = index

    const date = entries[current].dataset.date ?? ""
    if (dateEl) {
      dateEl.textContent = date
      dateEl.setAttribute("datetime", date)
    }

    newerBtn.disabled = current === 0
    olderBtn.disabled = current === entries.length - 1

    highlightDate(date)
    updateTrackerWindow(date)
  }

  newerBtn.addEventListener("click", () => show(current - 1))
  olderBtn.addEventListener("click", () => show(current + 1))

  trackerCells.forEach((cell) => {
    if (cell.classList.contains("tracker-cell--has-entry")) {
      cell.addEventListener("click", () => {
        const date = cell.dataset.date!
        const idx = Array.from(entries).findIndex(e => e.dataset.date === date)
        if (idx !== -1) {
          show(idx)
        }
      })
    }
  })

  // Initialise tracker window and recalculate on resize
  updateTrackerWindow(entries[0]?.dataset.date ?? "")

  window.addEventListener("resize", () => {
    updateTrackerWindow(entries[current]?.dataset.date ?? "")
  })
</script>

<style>
  .til-card {
    border: 0.0625rem solid rgb(var(--gray-light));
    border-radius: 0.5rem;
    padding: 1.25rem 1.5rem;
    box-shadow: var(--box-shadow);
    margin: 1.5rem 0;
  }

  .til-card-header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.75rem;
    border-bottom: 0.0625rem solid rgb(var(--gray-light));
  }

  .til-card-header-top {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }

  @media (min-width: 37.5625rem) {
    .til-card-header-top {
      flex-direction: row;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
    }
  }

  .til-label {
    font-weight: 700;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05rem;
  }

  .til-controls {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  time {
    font-size: 0.85rem;
    color: rgb(var(--gray));
  }

  .til-controls button {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    font-size: 0.85rem;
    color: rgb(var(--gray-dark));
    line-height: 1;
  }

  .til-controls button:hover:not(:disabled) {
    color: var(--accent);
  }

  .til-controls button:disabled {
    color: rgb(var(--gray-light));
    cursor: default;
  }

  .til-entries {
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgb(var(--gray-dark));
  }

  .til-entries :global(p) {
    margin: 0;
  }

  .til-entries :global(.til-day) {
    font-size: 0.8rem;
    color: rgb(var(--gray));
    margin: 0 0 0.4rem 0;
  }

  .til-card-footer {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 0.0625rem solid rgb(var(--gray-light));
  }

  .til-rss-link {
    font-size: 0.8rem;
    color: rgb(var(--gray));
    text-decoration: none;
  }

  .til-rss-link:hover {
    color: rgb(var(--gray-dark));
  }
</style>
