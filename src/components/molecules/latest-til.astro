---
import { getCollection, render } from "astro:content"

const MONTHS_TO_SHOW = 5

const entries = await getCollection("til")

const sorted = entries.sort((a, b) =>
  new Date(b.id).getTime() - new Date(a.id).getTime()
)

const rendered = await Promise.all(sorted.map(entry => render(entry)))

const dayNames = sorted.map(entry =>
  new Date(entry.id).toLocaleDateString("en-GB", { weekday: "long", timeZone: "UTC" })
)

// Build tracker grid data
const todayStr = new Date().toISOString().slice(0, 10)
const entryDates = new Set(sorted.map(e => e.id))
const now = new Date()

const trackerMonths = Array.from({ length: MONTHS_TO_SHOW }, (_, i) => {
  const d = new Date(now.getFullYear(), now.getMonth() - (MONTHS_TO_SHOW - 1 - i), 1)
  const year = d.getFullYear()
  const month = d.getMonth()
  const daysInMonth = new Date(year, month + 1, 0).getDate()
  // Monday-first offset: Mon=0 … Sun=6
  const mondayOffset = (new Date(year, month, 1).getDay() + 6) % 7

  const cells: { isPad: boolean; date: string | null; hasEntry: boolean; isFuture: boolean }[] = []

  for (let i = 0; i < mondayOffset; i++) {
    cells.push({ isPad: true, date: null, hasEntry: false, isFuture: false })
  }
  for (let day = 1; day <= daysInMonth; day++) {
    const dateStr = `${year}-${String(month + 1).padStart(2, "0")}-${String(day).padStart(2, "0")}`
    cells.push({
      isPad: false,
      date: dateStr,
      hasEntry: entryDates.has(dateStr),
      isFuture: dateStr > todayStr,
    })
  }
  // Pad to 42 cells so every month occupies exactly 6 rows
  while (cells.length < 42) {
    cells.push({ isPad: true, date: null, hasEntry: false, isFuture: false })
  }

  const label = d.toLocaleDateString("en-GB", { month: "short", year: "numeric" })
  return { label, cells }
})

const initialDate = sorted[0]?.id ?? ""
---

<aside class="til-card">
  <div class="til-card-header">
    <span class="til-label">Today I Learned</span>
    <div class="til-controls">
      <button id="til-older" aria-label="Older entry" disabled={sorted.length <= 1}>← Older</button>
      <time id="til-date" datetime={sorted[0].id}>{sorted[0].id}</time>
      <button id="til-newer" aria-label="Newer entry" disabled>Newer →</button>
    </div>
  </div>

  <div class="til-tracker" aria-hidden="true">
    {trackerMonths.map(({ label, cells }) => (
      <div class="tracker-month">
        <div class="tracker-month-label">{label}</div>
        <div class="tracker-grid">
          {["M","T","W","T","F","S","S"].map(d => (
            <div class="tracker-day-header">{d}</div>
          ))}
          {cells.map(cell => (
            <div
              class:list={[
                "tracker-cell",
                cell.isPad && "tracker-cell--pad",
                !cell.isPad && !cell.hasEntry && !cell.isFuture && "tracker-cell--empty",
                cell.hasEntry && "tracker-cell--has-entry",
                cell.isFuture && "tracker-cell--future",
                cell.date === initialDate && "tracker-cell--active",
              ]}
              data-date={cell.date ?? undefined}
            ></div>
          ))}
        </div>
      </div>
    ))}
  </div>

  <div class="til-entries">
    {rendered.map(({ Content }, i) => (
      <div class="til-entry" data-date={sorted[i].id} hidden={i !== 0}>
        <p class="til-day">{dayNames[i]}</p>
        <Content />
      </div>
    ))}
  </div>
  <div class="til-card-footer">
    <a href="/til-rss.xml" class="til-rss-link">RSS</a>
  </div>
</aside>

<script>
  const entries = document.querySelectorAll<HTMLElement>(".til-entry")
  const dateEl = document.getElementById("til-date")
  const newerBtn = document.getElementById("til-newer") as HTMLButtonElement
  const olderBtn = document.getElementById("til-older") as HTMLButtonElement
  const trackerCells = document.querySelectorAll<HTMLElement>(".tracker-cell[data-date]")

  let current = 0

  function highlightDate(date: string) {
    trackerCells.forEach(cell => {
      cell.classList.toggle("tracker-cell--active", cell.dataset.date === date)
    })
  }

  function show(index: number) {
    entries[current].hidden = true
    entries[index].hidden = false
    current = index

    const date = entries[current].dataset.date ?? ""
    if (dateEl) {
      dateEl.textContent = date
      dateEl.setAttribute("datetime", date)
    }

    newerBtn.disabled = current === 0
    olderBtn.disabled = current === entries.length - 1

    highlightDate(date)
  }

  newerBtn.addEventListener("click", () => show(current - 1))
  olderBtn.addEventListener("click", () => show(current + 1))

  trackerCells.forEach(cell => {
    if (cell.classList.contains("tracker-cell--has-entry")) {
      cell.addEventListener("click", () => {
        const date = cell.dataset.date!
        const idx = Array.from(entries).findIndex(e => e.dataset.date === date)
        if (idx !== -1) show(idx)
      })
    }
  })
</script>

<style>
  .til-card {
    border: 1px solid rgb(var(--gray-light));
    border-radius: 8px;
    padding: 1.25em 1.5em;
    box-shadow: var(--box-shadow);
    margin: 1.5em 0;
  }

  .til-card-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1em;
    margin-bottom: 0.75em;
    padding-bottom: 0.75em;
    border-bottom: 1px solid rgb(var(--gray-light));
  }

  .til-label {
    font-weight: 700;
    font-size: 0.9em;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .til-controls {
    display: flex;
    align-items: baseline;
    gap: 0.75em;
  }

  time {
    font-size: 0.85em;
    color: rgb(var(--gray));
  }

  .til-controls button {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    font-size: 0.85em;
    color: rgb(var(--gray-dark));
    line-height: 1;
  }

  .til-controls button:hover:not(:disabled) {
    color: var(--accent);
  }

  .til-controls button:disabled {
    color: rgb(var(--gray-light));
    cursor: default;
  }

  /* Tracker */
  .til-tracker {
    display: flex;
    justify-content: center;
    gap: 1.25em;
    overflow: hidden;
    margin-bottom: 0.75em;
  }

  .tracker-month {
    flex-shrink: 0;
  }

  /*
   * Each month block is 109px wide (7 × 13px cells + 6 × 3px gaps).
   * Desktop content width is fixed at 660px (720px container − 60px card padding).
   * Mobile content width is viewport − 90px (container + card padding at 18px font).
   *
   * 5 months: 645px → viewport ≥ 745px  (desktop default)
   * 4 months: 511px → viewport ≥ 601px
   * 3 months: 373px → viewport ≥ 463px
   * 2 months: 241px → viewport ≥ 331px
   * 1 month:  109px → any remaining width
   */
  @media (max-width: 744px) {
    .tracker-month:first-child {
      display: none;
    }
  }

  @media (max-width: 600px) {
    .tracker-month:nth-child(-n+2) {
      display: none;
    }
  }

  @media (max-width: 462px) {
    .tracker-month:nth-child(-n+3) {
      display: none;
    }
  }

  @media (max-width: 330px) {
    .tracker-month:nth-child(-n+4) {
      display: none;
    }
  }

  .tracker-month-label {
    font-size: 0.65em;
    color: rgb(var(--gray));
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 4px;
  }

  .tracker-grid {
    display: grid;
    grid-template-columns: repeat(7, 13px);
    gap: 3px;
  }

  .tracker-day-header {
    width: 13px;
    height: 13px;
    font-size: 7px;
    color: rgb(var(--gray));
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tracker-cell {
    width: 13px;
    height: 13px;
    border-radius: 2px;
  }

  .tracker-cell--pad {
    background: transparent;
  }

  .tracker-cell--empty {
    background: rgb(var(--gray-light));
  }

  .tracker-cell--future {
    background: rgb(var(--gray-light));
    opacity: 0.4;
  }

  .tracker-cell--has-entry {
    background: rgba(35, 55, 255, 0.35);
    cursor: pointer;
    transition: transform 0.1s ease, background 0.1s ease;
  }

  .tracker-cell--has-entry:hover {
    background: rgba(35, 55, 255, 0.6);
    transform: scale(1.25);
  }

  .tracker-cell--active {
    background: var(--accent) !important;
    box-shadow: 0 0 0 1.5px var(--accent-dark);
  }

  /* Entries */
  .til-entries {
    font-size: 0.95em;
    line-height: 1.6;
    color: rgb(var(--gray-dark));
  }

  .til-entries :global(p) {
    margin: 0;
  }

  .til-entries :global(.til-day) {
    font-size: 0.8em;
    color: rgb(var(--gray));
    margin: 0 0 0.4em 0;
  }

  .til-card-footer {
    margin-top: 0.75em;
    padding-top: 0.75em;
    border-top: 1px solid rgb(var(--gray-light));
  }

  .til-rss-link {
    font-size: 0.8em;
    color: rgb(var(--gray));
    text-decoration: none;
  }

  .til-rss-link:hover {
    color: rgb(var(--gray-dark));
  }
</style>
