---
import type { CollectionEntry } from "astro:content"
import { Image } from "astro:assets"

type Props = CollectionEntry<"projects">["data"]

const { title, url, description, screenshot } = Astro.props
---

<article class="project-card">
  {screenshot && (
    <a href={url} target="_blank" rel="noopener noreferrer" class="screenshot-link">
      <Image src={screenshot} alt={`Screenshot of ${title}`} width={720} height={480} />
    </a>
  )}
  <h3><a href={url} target="_blank" rel="noopener noreferrer">{title}</a></h3>
  <p>{description}</p>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    gap: 0.75em;
  }

  .screenshot-link img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    box-shadow: var(--box-shadow);
    transition: opacity 0.2s ease;
  }

  .screenshot-link:hover img {
    opacity: 0.85;
  }

  h3 {
    margin: 0 0 0.25em 0;
    font-size: 1.25em;
  }

  h3 a {
    color: rgb(var(--black));
    text-decoration: none;
  }

  h3 a:hover {
    color: var(--accent);
  }

  p {
    margin: 0;
    color: rgb(var(--gray));
  }
</style>
