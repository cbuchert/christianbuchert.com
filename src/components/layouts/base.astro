---
import BaseHead from "@/components/layouts/base-head.astro"
import Footer from "@/components/organisms/footer.astro"
import Header from "@/components/organisms/header.astro"

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Chris Buchert | ${title}`} description={description} />
  </head>
  <body>
    <Header />
    <main class="container">
      <slot />
    </main>
    <Footer />
  </body>
</html>
