---
import HeaderLink from "./header-link.astro";
---

<header>
  <div class="container">
    <nav>
      <h2><a href="/">Chris Buchert</a></h2>
      <div class="internal-links">
        <HeaderLink href="/technical-blog">Technical Blog</HeaderLink>
        <HeaderLink href="/projects">Side Projects</HeaderLink>
        <HeaderLink href="/about">About</HeaderLink>
      </div>
    </nav>
  </div>
</header>

<style>
  header {
    margin: 0;
    background: white;
    box-shadow: 0 2px 8px rgba(var(--black), 5%);
  }
  h2 {
    margin: 0;
    font-size: 1em;
  }
  h2 a,
  h2 a.active {
    text-decoration: none;
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  nav a {
    padding: 1em 0.5em;
    color: var(--black);
    border-bottom: 4px solid transparent;
    text-decoration: none;
  }
  nav a.active {
    text-decoration: none;
    border-bottom-color: var(--accent);
  }
  .social-links,
  .social-links a {
    display: flex;
  }
  @media (max-width: 720px) {
    .social-links {
      display: none;
    }
    nav {
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
    }
    .internal-links {
      display: flex;
      gap: 0.25em;
    }
  }
</style>
