---
import InternalLinks from "@/components/molecules/internal-links.astro"
---

<header>
  <div class="container">
    <nav>
      <h2><a href="/">Chris Buchert</a></h2>
      <InternalLinks />
    </nav>
  </div>
</header>

<style>
  header {
    margin: 0;
    background: white;
    box-shadow: 0 0.125rem 0.5rem rgba(var(--black), 5%);
  }
  h2 {
    margin: 0;
    font-size: 1rem;
  }
  h2 a,
  h2 a.active {
    text-decoration: none;
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  @media (max-width: 45rem) {
    nav {
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      padding-top: 0.75rem;
    }
  }
</style>
